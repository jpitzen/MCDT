{
  "name": "eks-deployer-backend",
  "version": "1.0.0",
  "description": "Automated AWS EKS Deployment Platform - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:all": "sequelize-cli db:migrate --to",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all"
  },
  "keywords": [
    "aws",
    "eks",
    "kubernetes",
    "automation",
    "deployment"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.940.0",
    "@aws-sdk/client-efs": "^3.940.0",
    "@aws-sdk/client-eks": "^3.940.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.940.0",
    "@azure/identity": "^4.13.0",
    "@azure/keyvault-secrets": "^4.10.0",
    "aws-sdk": "^2.1525.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "child-process-promise": "^2.2.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.7",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "mssql": "^12.1.1",
    "mysql2": "^3.15.3",
    "node-vault": "^0.9.22",
    "nodemailer": "^7.0.10",
    "pg": "^8.16.3",
    "sequelize": "^6.35.1",
    "sequelize-cli": "^6.6.2",
    "socket.io": "^4.8.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
