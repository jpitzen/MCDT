<!-- //Settings for Image/OCR documents -->
<Group>
	<GroupName>OCR Settings</GroupName>
	<GroupDisplayName>OCR Settings</GroupDisplayName>
	<GroupDesc>OCR Settings</GroupDesc>
	
	<Bean>
     <BeanName>APPMODULE_OCR_ON</BeanName>
     <BeanDisplayName>Enable OCR for attachments</BeanDisplayName>
     <BeanValue>false</BeanValue>
     <BeanType>PreprocessDefine</BeanType>
     <BeanInputType>CHECKBOX</BeanInputType>
     <BeanChoices>
        <CHOICE value="true"></CHOICE>
     </BeanChoices>
     <BeanHelp><![CDATA[Enable OCR for image based attachments.]]></BeanHelp>
   	</Bean>
   <Bean>
     <BeanName>_docConversion.ocr.extensions</BeanName>
     <BeanDisplayName>OCR associated extensions</BeanDisplayName>
     <BeanValue>jpg;jpeg;tiff;tif;bmp;gif;png</BeanValue>
     <BeanType>String</BeanType>
     <BeanInputType>TEXT</BeanInputType>
     <BeanHelp><![CDATA[A semicolon separated list of extensions which the Conversion server will consider for OCR.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>_docConversion.ocr.mimeTypes</BeanName>
     <BeanDisplayName>OCR associated mime-types</BeanDisplayName>
     <BeanValue>image/jpeg;image/pjpeg;image/tiff;image/tif;image/bmp;image/gif;image/png</BeanValue>
     <BeanType>String</BeanType>
     <BeanInputType>TEXT</BeanInputType>
     <BeanHelp><![CDATA[A semicolon separated list of mime-types which the Conversion server will consider for OCR.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>_docConversion.ocr.attachmentSize</BeanName>
     <BeanDisplayName>Size limit of attachments (in KB) </BeanDisplayName>
     <BeanValue>51200</BeanValue>
     <BeanType>Integer</BeanType>
     <BeanInputType size="6">TEXT</BeanInputType>
     <BeanHelp><![CDATA[Attachments larger than this size will not be OCR.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>PDF_OUTOFPROCESS_ON</BeanName>
     <BeanDisplayName>Enable PDF processing using ZLPDFConvertor process</BeanDisplayName>
     <BeanValue>false</BeanValue>
     <BeanType>PreprocessDefine</BeanType>
     <BeanInputType caption="true">CHECKBOX</BeanInputType>
     <BeanChoices>
       <Choice value="true"></Choice>
     </BeanChoices>
     <BeanHelp><![CDATA[For PDF documents that require OCR, enable this option to use ZLPDFConvertor which is an external process that will process PDF files before sending them for OCR to ZLOCRConvertor. If this option is unchecked, the PDF processing will be performed within the ZL Server process.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>_docConversion.ocr.maxPDFImagePages</BeanName>
     <BeanDisplayName>Maximum PDF Image Pages </BeanDisplayName>
     <BeanValue>100</BeanValue>
     <BeanType>Integer</BeanType>
     <BeanInputType size="6">TEXT</BeanInputType>
     <BeanHelp><![CDATA[Specifies Maximum PDF pages with images. If the PDF doc exceeds this number, OCR conversion will be skipped.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>_docConversion.ocr.minImageResolution</BeanName>
     <BeanDisplayName>Minimum Supported Image Resolution</BeanDisplayName>
     <BeanValue>16</BeanValue>
     <BeanType>Integer</BeanType>
     <BeanInputType size="6">TEXT</BeanInputType>
     <BeanHelp><![CDATA[Specifies minimum resolution in pixels (height and width) of images to be considered for OCR. Any image whose height and width are above the specified threshold will be considered for OCR.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>_docConversion.ocr.maxImageResolution</BeanName>
     <BeanDisplayName>Maximum Supported Image Resolution</BeanDisplayName>
     <BeanValue>8400</BeanValue>
     <BeanType>Integer</BeanType>
     <BeanInputType size="6">TEXT</BeanInputType>
     <BeanHelp><![CDATA[Specifies maximum resolution in pixels (height and width) of images to be considered for OCR. Any image whose height and width are below the specified threshold will be considered for OCR.]]></BeanHelp>
   </Bean>
   <Bean>
	<BeanName>_docConversion.ocr.forceLanguage.on</BeanName>
	<BeanDisplayName>Force OCR Detection Language</BeanDisplayName>
	<BeanValue>false</BeanValue>
	<BeanType>Boolean</BeanType>
	<BeanInputType size="6">CHECKBOX</BeanInputType>
	<BeanChoices>
		<CHOICE value="true"></CHOICE>
	</BeanChoices>
	<BeanHelp><![CDATA[Force OCR Conversion to use the selected language from the OCR Detection Languages setting below.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>_docConversion.ocr.Language</BeanName>
     <BeanDisplayName>OCR Detection Languages</BeanDisplayName>
     <BeanValue>SYSTEMDEFAULT</BeanValue>     
     <BeanInputType>SELECT</BeanInputType>
     <BeanChoices>
        <CHOICE value="SYSTEMDEFAULT">System Default</CHOICE>
        <CHOICE value="en">English</CHOICE>
        <CHOICE value="jp">Japanese</CHOICE>
        <CHOICE value="kr">Korean</CHOICE>
        <CHOICE value="latin">All Latin Languages</CHOICE>
        <CHOICE value="asian">All Asian Languages</CHOICE>
     </BeanChoices>
     <BeanHelp><![CDATA[Select the language that the OCR Convertor should use for detection. System Default will use the system's default language. All Latin will include all Latin based languages. All Asian will include Chinese, Japanese, Korean, Thai. The accuracy of the OCR engine improves if a specific language is set for detection. Multiple languages can be selected here.]]></BeanHelp>
   </Bean>    
      
</Group>

<Group>
   <GroupName>ZLOCR Service Settings</GroupName>
   <GroupDisplayName>ZLOCR Service Settings</GroupDisplayName>
   <GroupDesc><![CDATA[Setting related to the ZLOCR Service.]]></GroupDesc>

	<Bean>
     <BeanName>__ocr.ZLOCRService.Host</BeanName>
     <BeanDisplayName>ZL OCR Service Host</BeanDisplayName>
     <BeanValue>zltika</BeanValue>
     <BeanType>String</BeanType>
     <BeanInputType>TEXT</BeanInputType>
     <BeanHelp><![CDATA[Location of ZLOCR service/process.]]></BeanHelp>
   </Bean>
   
   <Bean>
     <BeanName>__ocr.ZLOCRService.conversionPort</BeanName>
     <BeanDisplayName>OCR Conversion server port</BeanDisplayName>
     <BeanValue>9977</BeanValue>
     <BeanType>Integer</BeanType>
     <BeanInputType size="6">TEXT</BeanInputType>
     <BeanHelp><![CDATA[Port number where the ZL OCR conversion server is listening.]]></BeanHelp>
   </Bean>


   <Bean>
     <BeanName>__ocr.ZLOCRService.tMaxConversionPerDoc</BeanName>
     <BeanDisplayName>Max Allowed Conversion Time</BeanDisplayName>
      <BeanValue>300000</BeanValue>
    <BeanType>Integer</BeanType>
     <BeanInputType size="6">TIME</BeanInputType>
     <BeanHelp><![CDATA[The OCR convertor is given the specified time to convert. If it takes more than this time, we deem the ZLKv service to have hanged while converting this document.]]></BeanHelp>
   </Bean>


   <Bean>
     <BeanName>__ocr.ZLOCRService.t1Cool</BeanName>
     <BeanDisplayName>ZLOCR Service Auto Restart Threshold 1</BeanDisplayName>
      <BeanValue>10800000</BeanValue>
    <BeanType>Integer</BeanType>
     <BeanInputType size="6">TIME</BeanInputType>
     <BeanHelp><![CDATA[If the ZLOCR service hasnt been restarted for this duration and the service is not used by any task, the service is restarted]]></BeanHelp>
   </Bean>

   <Bean>
     <BeanName>__ocr.ZLOCRService.t2Anxi</BeanName>
     <BeanDisplayName>ZLOCR Service Auto Restart Threshold 2</BeanDisplayName>
      <BeanValue>21600000</BeanValue>
    <BeanType>Integer</BeanType>
     <BeanInputType size="6">TIME</BeanInputType>
     <BeanHelp><![CDATA[If the ZLOCR Service hasnt been restarted for this duration and if all the processes currently using the service have been doing so for a period greater than the ZLKv Session Age Threshold, the service is restarted]]></BeanHelp>
   </Bean>

   <Bean>
     <BeanName>__ocr.ZLOCRService.t3Desp</BeanName>
     <BeanDisplayName>ZLOCR Service Auto Restart Threshold 3</BeanDisplayName>
      <BeanValue>43200000</BeanValue>
    <BeanType>Integer</BeanType>
     <BeanInputType size="6">TIME</BeanInputType>
     <BeanHelp><![CDATA[If the ZLOCR Service hasnt been restarted for this period, it is restarted by force irrespective of whether it is idle or not.]]></BeanHelp>
   </Bean>

   <Bean>
     <BeanName>__ocr.ZLOCRService.tSessionAgeThreshold</BeanName>
     <BeanDisplayName>ZLOCR Service Session Age Threshold</BeanDisplayName>
      <BeanValue>1800000</BeanValue>
    <BeanType>Integer</BeanType>
     <BeanInputType size="6">HIDDEN</BeanInputType>
     <BeanHelp><![CDATA[When a process uses the ZLOCR Service, it is given a session of this duration for the purpose. Beyond this duration, the session is deemed old and the ZLKv automatic restart can interrupt the session]]></BeanHelp>
   </Bean>

</Group>


