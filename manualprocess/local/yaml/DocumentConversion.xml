<Sheet> 
<SheetName>DocumentConversion</SheetName>
<SheetDisplayName>Document Conversion</SheetDisplayName>
<SheetDesc><![CDATA[Document conversion settings]]></SheetDesc>

<!-- Global Conversion Settings -->
<Group>
   <GroupName>Global Document Conversion Settings</GroupName>
   <GroupDisplayName>Global Document Conversion Settings</GroupDisplayName>
   <GroupDesc><![CDATA[Settings for Document Conversion. These settings apply to all types document conversions]]></GroupDesc>

	<Bean>
     <BeanName>DOCCONVERSION_FILEDETECT_ON</BeanName>
     <BeanDisplayName>Enable file type detection for document conversion</BeanDisplayName>
     <BeanValue>false</BeanValue>
     <BeanType>PreprocessDefine</BeanType>
     <BeanInputType caption="true">CHECKBOX</BeanInputType>
     <BeanChoices>
       <Choice value="true"></Choice>
     </BeanChoices>
     <BeanHelp><![CDATA[Enable best-effort file type detection for documents. This setting will force detection of file type based on the file magic headers to determine whether the files are what their extensions or mime-types declare them to be. Enable this setting if the environment has files/attachments with incorrect extensions or mimetypes. Enabling this setting has a minor performance impact.]]></BeanHelp>
   </Bean>
   
</Group>

<!-- //Tika Service Manager -->
<Group>
	<GroupName>ZLTika Service Settings</GroupName>
	<GroupDisplayName>ZLTika Service Settings</GroupDisplayName>
	<GroupDesc><![CDATA[Setting related to the ZLTika Doc Conversion Service.]]></GroupDesc>



	<Bean>
		<BeanName>__tika.ZLTikaService.Host</BeanName>
		<BeanDisplayName>Tika Service Host</BeanDisplayName>
		<BeanValue>zltika</BeanValue>
		<BeanType>String</BeanType>
		<BeanInputType>TEXT</BeanInputType>
		<BeanHelp><![CDATA[Location of Tika doc conversion service/process.]]></BeanHelp>
	</Bean>

	<Bean>
		<BeanName>__tika.ZLTikaService.Port</BeanName>
		<BeanDisplayName>ZL Tika  Port</BeanDisplayName>
		<BeanValue>9972</BeanValue>
		<BeanType>Integer</BeanType>
		<BeanInputType size="6">TEXT</BeanInputType>
		<BeanHelp><![CDATA[Port number where the Tika Doc Conversion server is listening.]]></BeanHelp>
	</Bean>

	<Bean>
		<BeanName>__tika.ZLTikaService.tMaxConversionPerDoc</BeanName>
		<BeanDisplayName>Max Allowed Conversion Time</BeanDisplayName>
		<BeanValue>300000</BeanValue>
		<BeanType>Integer</BeanType>
		<BeanInputType size="6">TIME</BeanInputType>
		<BeanHelp><![CDATA[The Tika convertor is given the specified time to convert. If it takes more than this time, we deem the ZLTika service to have hanged while converting this document.]]></BeanHelp>
	</Bean>


	<Bean>
		<BeanName>__tika.ZLTikaService.t1Cool</BeanName>
		<BeanDisplayName>ZLTika Service Auto Restart Threshold 1</BeanDisplayName>
		<BeanValue>10800000</BeanValue>
		<BeanType>Integer</BeanType>
		<BeanInputType size="6">TIME</BeanInputType>
		<BeanHelp><![CDATA[If the ZLTika service hasnt been restarted for this duration and the service is not used by any task, the service is restarted]]></BeanHelp>
	</Bean>

	<Bean>
		<BeanName>__tika.ZLTikaService.t2Anxi</BeanName>
		<BeanDisplayName>ZLTika service Auto Restart Threshold 2</BeanDisplayName>
		<BeanValue>21600000</BeanValue>
		<BeanType>Integer</BeanType>
		<BeanInputType size="6">TIME</BeanInputType>
		<BeanHelp><![CDATA[If the ZLTika Service hasnt been restarted for this duration and if all the processes currently using the service have been doing so for a period greater than the ZLtika Session Age Threshold, the service is restarted]]></BeanHelp>
	</Bean>

	<Bean>
		<BeanName>__tika.ZLTikaService.t3Desp</BeanName>
		<BeanDisplayName>ZLTika service Auto Restart Threshold 3</BeanDisplayName>
		<BeanValue>43200000</BeanValue>
		<BeanType>Integer</BeanType>
		<BeanInputType size="6">TIME</BeanInputType>
		<BeanHelp><![CDATA[If the ZLTika service hasnt been restarted for this period, it is restarted by force irrespective of whether it is idle or not.]]></BeanHelp>
	</Bean>

	<Bean>
		<BeanName>__tika.ZLTikaService.tSessionAgeThreshold</BeanName>
		<BeanDisplayName>ZLTika service Session Age Threshold</BeanDisplayName>
		<BeanValue>1800000</BeanValue>
		<BeanType>Integer</BeanType>
		<BeanInputType size="6">HIDDEN</BeanInputType>
		<BeanHelp><![CDATA[When a process uses the ZLTika Service, it is given a session of this duration for the purpose. Beyond this duration, the session is deemed old and the ZLtika automatic restart can interrupt the session]]></BeanHelp>
	</Bean>

	<Bean>
		<BeanName>__tika.formatsSignature</BeanName>
		<BeanDisplayName>Signature of Formats.ini</BeanDisplayName>
		<BeanValue>GZ6PYKzXj1mFhjLRwIyukETvMRU=</BeanValue>
		<BeanType>String</BeanType>
		<BeanInputType size="6">HIDDEN</BeanInputType>
		<BeanHelp><![CDATA[Location of ZLTika doc conversion service/process.]]></BeanHelp>
	</Bean>

	<Bean>
		<BeanName>__tika.ZLTikaService.tEmbedExtractionRecursiveLevels</BeanName>
		<BeanDisplayName>Max Ole Extraction Recursive level</BeanDisplayName>
		<BeanValue>0</BeanValue>
		<BeanType>Integer</BeanType>
		<BeanInputType size="3">TEXT</BeanInputType>
		<BeanHelp><![CDATA[Documents like word,PDF, spreadsheets can contain ole objects as embedded objects and this value sets the Maximum level of depth the recursion can go to extract Ole objects]]></BeanHelp>
	</Bean>


</Group>


<!-- //Settings for Text/HTML documents -->
<Group>
	<GroupName>Text/HTML Settings</GroupName>
	<GroupDisplayName>Settings for Text/HTML documents</GroupDisplayName>
	<GroupDesc>Settings for Text/HTML documents</GroupDesc>
    <Bean>
     <BeanName>_docConversion.html.on</BeanName>
     <BeanDisplayName>Enable indexing of document attachments</BeanDisplayName>
     <BeanValue>true</BeanValue>
     <BeanType>Boolean</BeanType>
     <BeanInputType caption="true">CHECKBOX</BeanInputType>
     <BeanChoices>
       <Choice value="true"></Choice>
     </BeanChoices>
     <BeanHelp><![CDATA[Enable indexing of document attachments.]]></BeanHelp>
   </Bean>
    <Bean>
     <BeanName>_docConversion.text.stats.on</BeanName>
     <BeanDisplayName>Enable check to determine files have text content</BeanDisplayName>
     <BeanValue>false</BeanValue>
     <BeanType>Boolean</BeanType>
     <BeanInputType caption="true">CHECKBOX</BeanInputType>
     <BeanChoices>
       <Choice value="true"></Choice>
     </BeanChoices>
     <BeanHelp><![CDATA[Perform best-effort extra check in addition to extension and mime-type to determine if file/attachment really has textual content. This method performs a heuristic on a section of the file/attachment to quickly determine if the file has textual content. If the check determines that the file has Textual content then the file proceeds to be indexed otherwise the file/attachment is rejected and marked as not-supported for indexing. This check is best used in conjunction with file-type detection setting turned on. It should be noted that there is a minor performance impact if this check is turned on.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>_docConversion.html.extensions</BeanName>
     <BeanDisplayName>Index documents with these extensions</BeanDisplayName>
     <BeanValue>txt;html;htm</BeanValue>
     <BeanType>String</BeanType>
     <BeanInputType>TEXT</BeanInputType>
     <BeanHelp><![CDATA[A semicolon separated list of extensions which the conversion engine will try to convert.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>_docConversion.html.mimeTypes</BeanName>
     <BeanDisplayName>Index documents with these mime-types</BeanDisplayName>
     <BeanValue>text/plain;text/html;text/htm</BeanValue>
     <BeanType>String</BeanType>
     <BeanInputType>TEXT</BeanInputType>
     <BeanHelp><![CDATA[A semicolon separated list of mime-types which the conversion engine will try to convert.]]></BeanHelp>
   </Bean>
   <Bean>
     <BeanName>_docConversion.html.attachmentSize</BeanName>
     <BeanDisplayName>Size limit of attachments (in KB) </BeanDisplayName>
     <BeanValue>10240</BeanValue>
     <BeanType>Integer</BeanType>
     <BeanInputType size="6">TEXT</BeanInputType>
     <BeanHelp><![CDATA[HTML/Text attachments larger than this size will not be scanned.]]></BeanHelp>
   </Bean> 	
</Group>





