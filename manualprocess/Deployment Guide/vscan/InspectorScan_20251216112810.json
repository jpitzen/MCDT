it input, causing reads up to 2 bytes beyond allocated buffer boundaries. This issue has been patched in version 1.6.51.","title":"CVE-2025-64506 - libpng16-16","remediation":{"recommendation":{"text":"None Provided"}},"severity":"MEDIUM","firstObservedAt":"2025-12-16T06:26:53.815000-05:00","lastObservedAt":"2025-12-16T09:23:29.356000-05:00","updatedAt":"2025-12-16T09:23:29.356000-05:00","status":"ACTIVE","resources":[{"type":"AWS_ECR_CONTAINER_IMAGE","id":"arn:aws:ecr:us-west-1:995553364920:repository/uw1-zlps-ecr-01/sha256:e6a96c16ef83659fe2acf60c0566f40071aebe91557ffb1b6fb980d6fa0eca39","partition":"aws","region":"us-west-1","tags":{},"details":{"awsEcrContainerImage":{"repositoryName":"uw1-zlps-ecr-01","imageTags":["zlserver-11.0.1-b123-v2"],"pushedAt":"2025-12-08T13:26:55.476000-05:00","architecture":"amd64","imageHash":"sha256:e6a96c16ef83659fe2acf60c0566f40071aebe91557ffb1b6fb980d6fa0eca39","registry":"995553364920","platform":"UBUNTU_22_04"}}}],"inspectorScore":6.1,"inspectorScoreDetails":{"adjustedCvss":{"scoreSource":"UBUNTU_CVE","cvssSource":"UBUNTU_CVE","version":"3.1","score":6.1,"scoringVector":"CVSS:3.1/AV:L/AC:L/PR:N/UI:R/S:U/C:L/I:N/A:H","adjustments":[]}},"packageVulnerabilityDetails":{"vulnerabilityId":"CVE-2025-64506","vulnerablePackages":[{"name":"libpng16-16","version":"1.6.37","sourceLayerHash":"sha256:6ae46d52fd25be7f6725a2f58d1689f56dd3eea912130213545bb26d0d7fa363","epoch":0,"release":"3build5","arch":"AMD64","packageManager":"OS","fixedInVersion":"0:1.6.37-3ubuntu0.1","remediation":"apt-get update \u0026\u0026 apt-get upgrade"}],"source":"UBUNTU_CVE","cvss":[{"baseScore":6.1,"scoringVector":"CVSS:3.1/AV:L/AC:L/PR:N/UI:R/S:U/C:L/I:N/A:H","version":"3.1","source":"UBUNTU_CVE"},{"baseScore":6.1,"scoringVector":"CVSS:3.1/AV:L/AC:L/PR:N/UI:R/S:U/C:L/I:N/A:H","version":"3.1","source":"NVD"}],"relatedVulnerabilities":["USN-7924-1"],"sourceUrl":"https://people.canonical.com/~ubuntu-security/cve/2025/CVE-2025-64506.html","vendorSeverity":"medium","v