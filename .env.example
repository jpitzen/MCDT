# AWS EKS Deployer - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ==============================================================================
# BACKEND CONFIGURATION
# ==============================================================================

# Node environment
NODE_ENV=development

# Server port
PORT=5000

# Database connection string
DATABASE_URL=postgresql://eks_user:eks_password_123@localhost:5436/eks_deployer

# JWT secret for token signing (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# HashiCorp Vault Configuration
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=myroot

# Redis Configuration (for caching and job queues)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================

# React App - Backend API URL
REACT_APP_API_URL=http://localhost:5000/api

# Frontend logging level
REACT_APP_LOG_LEVEL=info

# ==============================================================================
# EKS DEPLOYMENT CONFIGURATION
# ==============================================================================

# Cluster name
CLUSTER_NAME=eks-demo-cluster

# AWS Region for deployment
AWS_REGION_DEPLOY=us-east-1

# Kubernetes version
KUBERNETES_VERSION=1.30

# Node group configuration
NODE_TYPE=t3.medium
MIN_NODES=2
MAX_NODES=10
DESIRED_NODES=3

# RDS Configuration
RDS_ENGINE=sqlserver-se
RDS_INSTANCE_CLASS=db.t3.medium
RDS_ALLOCATED_STORAGE=100
RDS_DB_NAME=eksMainDb
RDS_USERNAME=admin
RDS_PASSWORD=YourSecurePassword123!

# Storage Configuration
ENABLE_EBS=true
ENABLE_EFS=true
ENABLE_S3=true

# Enable Autoscaling
ENABLE_AUTOSCALING=true

# ==============================================================================
# SECURITY & VAULT
# ==============================================================================

# Vault auth method
VAULT_AUTH_METHOD=token

# Enable credential encryption
ENABLE_CREDENTIAL_ENCRYPTION=true

# Encryption key (use a strong random string, exactly 32 characters)
# Also used to encrypt AD/LDAP service account passwords.
# If not set, derives from JWT_SECRET (not recommended for production).
ENCRYPTION_KEY=your-encryption-key-32-characters-long

# ==============================================================================
# JWT & SESSION
# ==============================================================================

# Access token expiry (default 1h)
ACCESS_TOKEN_EXPIRY=1h

# Refresh token expiry (default 7d)
REFRESH_TOKEN_EXPIRY=7d

# Idle session timeout in minutes (frontend shows warning 5 min before)
SESSION_IDLE_TIMEOUT=30

# ==============================================================================
# AD / LDAP AUTHENTICATION (Optional)
# ==============================================================================
# AD configuration is stored in the database (ad_configurations table)
# and managed through the System Admin → AD / LDAP tab. These env vars
# provide defaults and overrides only.

# Cron-style schedule for automatic AD user sync (empty = disabled)
# Default: every 60 minutes. Uses node-cron format.
AD_SYNC_SCHEDULE=*/60 * * * *

# ==============================================================================
# MONITORING & LOGGING
# ==============================================================================

# CloudWatch Configuration
ENABLE_CLOUDWATCH=true
CLOUDWATCH_LOG_GROUP=/aws/eks/deployer

# Deployment logs directory
LOG_DIR=./logs/deployments

# ==============================================================================
# DOCKER COMPOSE SPECIFIC
# ==============================================================================

# PostgreSQL
POSTGRES_USER=eks_user
POSTGRES_PASSWORD=eks_password_123
POSTGRES_DB=eks_deployer

# ==============================================================================
# TERRAFORM STREAMING
# ==============================================================================

# Terraform streaming timeout (ms). Default: 3600000 (60 min).
# Increase for slow cloud providers (e.g. Azure AKS can take 30+ min).
TERRAFORM_STREAM_TIMEOUT_MS=3600000

# ==============================================================================
# NOTES
# ==============================================================================
# 1. Never commit the .env file with real secrets to version control
# 2. Use strong random values for secrets (JWT_SECRET, passwords, etc.)
# 3. In production, use AWS Secrets Manager or similar services
# 4. Rotate secrets regularly
# 5. Restrict file permissions: chmod 600 .env
